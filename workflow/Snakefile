import csv
import os
import sys

configfile: "config/config.yaml"

# -----------------------------------------------------------------------------
# Read sample sheet
# -----------------------------------------------------------------------------
SAMPLES = {}
with open(config["sample_sheet"], newline="") as f:
    reader = csv.DictReader(f, delimiter="\t")
    for row in reader:
        sample = row["sample"].strip()
        SAMPLES[sample] = {
            "r1": row["r1"].strip(),
            "r2": row["r2"].strip(),
        }

# -----------------------------------------------------------------------------
# Check Bakta database
# -----------------------------------------------------------------------------
if not os.path.isdir(config["bakta"]["db_path"]):
    print(f"WARNING: Bakta database not found at {config['bakta']['db_path']}", file=sys.stderr)
    print("Download it with: bakta_db download --output " + config["bakta"]["db_path"], file=sys.stderr)
    # workflow will fail when bakta runs; just a friendly early warning

# -----------------------------------------------------------------------------
# Include all rule files
# -----------------------------------------------------------------------------
include: "rules/qc.smk"
include: "rules/trimming.smk"
include: "rules/assembly.smk"
include: "rules/evaluation.smk"
include: "rules/annotation.smk"
include: "rules/report.smk"

# -----------------------------------------------------------------------------
# Top‑level targets (Snakemake --report not included; run it manually afterwards)
# -----------------------------------------------------------------------------
rule all:
    input:
        # per‑sample annotation (ensures whole pipeline runs)
        expand("results/{sample}/07_bakta/annotation.gff3", sample=SAMPLES.keys()),
        # multi‑sample aggregation
        "results/multiqc/multiqc_report.html",
        # provenance
        "results/provenance/config.yaml",
        "results/provenance/software_versions.yml",
        "results/provenance/checksums.tsv",
        "results/provenance/runtime.tsv",
